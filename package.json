{
  "name": "omdala",
  "private": true,
  "version": "0.1.0",
  "description": "OMDALA — The global operating layer for real-world value, trust, and intelligent coordination.",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build":     "turbo build",
    "dev":       "turbo dev",
    "lint":      "turbo lint",
    "typecheck": "turbo typecheck",
    "clean":     "turbo clean && find . -name 'node_modules' -type d -prune -not -path './.git/*' | xargs rm -rf",
    "format":    "prettier --write \"**/*.{ts,tsx,js,json,md,css}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@types/node":      "^20.17.0",
    "prettier":         "^3.3.0",
    "turbo":            "^2.3.0",
    "typescript":       "^5.6.0"
  },
  "turbo": {}
}
