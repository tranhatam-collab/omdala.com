{
  "openapi": "3.1.0",
  "info": {
    "title": "AI Omniverse O1 Contract",
    "version": "0.1.0",
    "description": "Phase O1 contract for login and room state flow."
  },
  "servers": [
    {
      "url": "https://api.omdala.com"
    }
  ],
  "paths": {
    "/v2/omniverse/auth/login": {
      "post": {
        "summary": "Login with shared-core credentials",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authenticated Omniverse session"
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/v2/omniverse/rooms/{roomId}/state": {
      "get": {
        "summary": "Get current room state",
        "parameters": [
          {
            "in": "path",
            "name": "roomId",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "in": "header",
            "name": "Authorization",
            "required": true,
            "schema": { "type": "string", "example": "Bearer omni_xxx" }
          }
        ],
        "responses": {
          "200": {
            "description": "Room state payload"
          },
          "403": {
            "description": "Workspace access forbidden"
          },
          "401": {
            "description": "Missing or invalid token"
          },
          "404": {
            "description": "Room not found"
          }
        }
      }
    },
    "/v2/omniverse/flows/login-room-state": {
      "post": {
        "summary": "Run O1 flow: login then fetch room state",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "roomId"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" },
                  "roomId": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session and room state"
          }
        }
      }
    }
  }
}
