# OMDALA — Environment Variables Example
# Copy to .env.local for local development
# Never commit .env files with real values

# ─── App URLs ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://omdala.com
NEXT_PUBLIC_APP_APP_URL=https://app.omdala.com
NEXT_PUBLIC_API_URL=https://api.omdala.com

# ─── API ──────────────────────────────────────────────────────────────────
API_SECRET=

# ─── Analytics ────────────────────────────────────────────────────────────
NEXT_PUBLIC_ANALYTICS_ID=

# ─── Auth ─────────────────────────────────────────────────────────────────
AUTH_SECRET=
AUTH_URL=https://app.omdala.com

# ─── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=

# ─── Cloudflare ───────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=93112cc89181e75335cbd7ef7e392ba3
CLOUDFLARE_PAGES_PROJECT_WEB=omdala-web
CLOUDFLARE_PAGES_PROJECT_APP=omdala-app
CLOUDFLARE_PAGES_PROJECT_ADMIN=omdala-admin
CLOUDFLARE_PAGES_PROJECT_DOCS=omdala-docs
CLOUDFLARE_WORKER_API_NAME=omdala-api
