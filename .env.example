# OMDALA — Environment Variables Example
# Copy to .env.local for local development
# Never commit .env files with real values

# ─── App URLs ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://omdala.com
NEXT_PUBLIC_APP_APP_URL=https://app.omdala.com
NEXT_PUBLIC_API_URL=https://api.omdala.com

# ─── API ──────────────────────────────────────────────────────────────────
API_SECRET=
APP_BASE_URL=https://app.omdala.com
WEB_BASE_URL=https://omdala.com
MAIL_API_URL=https://mail.iai.one/_mail
MAIL_API_KEY=
MAGIC_LINK_SECRET=

# ─── Analytics ────────────────────────────────────────────────────────────
NEXT_PUBLIC_ANALYTICS_ID=

# ─── Auth ─────────────────────────────────────────────────────────────────
AUTH_SECRET=
AUTH_URL=https://app.omdala.com

# ─── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=

# ─── Smoke test (scripts/smoke_v2_reality.sh) ─────────────────────────────
# API base for smoke runner. Keep production default unless testing preview.
BASE_URL=https://omdala-api.tranhatam66.workers.dev
# 1 = run cleanup SQL after smoke write tests, 0 = skip cleanup.
SMOKE_CLEANUP=1
# CI strict mode script requires DATABASE_URL and enforces cleanup success.
# Run: bash scripts/smoke_v2_reality_ci.sh
# Optional custom env file path for smoke script secret loading.
ENV_FILE=.env
# Optional node IDs used when creating synthetic commitment/proof data.
FROM_NODE_ID=node_a
TO_NODE_ID=node_b
# Optional trust assert input files for assert-only script.
BEFORE_FILE=/tmp/omdala_smoke_trust_before.json
AFTER_FILE=/tmp/omdala_smoke_trust_after.json
# Latency gate for smoke script (ms).
SMOKE_P95_THRESHOLD_MS=2500
# Critical route p95 gate for write/trust flow (ms).
SMOKE_CRITICAL_ROUTE_P95_THRESHOLD_MS=2200
# 1 = fail smoke when p95 exceeds threshold, 0 = only report.
SMOKE_ENFORCE_P95=1

# --- Ops daily check budgets / upload --------------------------------------
# Optional cache file from Cloudflare log query exports.
LOG_CACHE_FILE=reports/ops/cache/v2-log-query-cache.json
# Optional source export file for building cache.
LOG_EXPORT_FILE=
# Error budget thresholds (24h).
BUDGET_DATABASE_TIMEOUT=20
BUDGET_DATABASE_UNAVAILABLE=5
BUDGET_DATABASE_CONSTRAINT_FOREIGN_KEY=30
BUDGET_DATABASE_CONSTRAINT_UNIQUE=20
BUDGET_DATABASE_CONSTRAINT_VIOLATION=30
# Optional upload target for daily JSON report.
# If REPORT_UPLOAD_URL is set, script POSTs JSON there.
REPORT_UPLOAD_URL=
REPORT_UPLOAD_TOKEN=
# If REPORT_UPLOAD_URL is empty and REPORT_UPLOAD_DIR is set, JSON is copied to this directory.
REPORT_UPLOAD_DIR=

# --- E2E --------------------------------------------------------------------
# Default Playwright base URL (overrides apps/web/playwright.config.ts default).
E2E_BASE_URL=https://omdala-web.pages.dev

# ─── Cloudflare ───────────────────────────────────────────────────────────
# Required for: pnpm deploy:* (wrangler pages deploy). Create a token in Cloudflare Dashboard.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=93112cc89181e75335cbd7ef7e392ba3
CLOUDFLARE_PAGES_PROJECT_WEB=omdala-web
CLOUDFLARE_PAGES_PROJECT_APP=omdala-app
CLOUDFLARE_PAGES_PROJECT_ADMIN=omdala-admin
CLOUDFLARE_PAGES_PROJECT_DOCS=omdala-docs
CLOUDFLARE_WORKER_API_NAME=omdala-api
